<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smoketrees Digital | Forgot Password</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible&family=Inter:wght@100..900&display=swap");
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: Inter, Arial, 'Google Sans';
      }
      body {
        width: 700px;
        margin: auto;
      }
      .footer {
        padding: 24px 80px 24px 80px;
        background-color: #333333 ;
        width: 700px;
        margin: auto;
      }
      .footerLinks {
        font-size: 12px;
        line-height: 14.52px;
        color: white;
        vertical-align: top;
      }
       .main {
        background-color: white ;
        color: #143D45 ;
        width: 700px;
        margin: auto;
      }
      img {
        width: 100%;
        display: block;
      }
      .mainContent {
        padding: 30px 80px;
      }
      h1 {
        margin-bottom: 20px;
        font-size: 41px;
        font-weight: 500;
        line-height: 49.62px;
      }
      p {
        font-size: 20px;
        line-height: 24.2px;
        text-align: left;
      }
    </style>
  </head>
  <body>
    <div class="main">
      <div class="mainContent">
        <img src="https://smoketrees.in/wp-content/uploads/2026/02/cropped-logo.png" alt="" style="width: 150px;object-fit: cover;"/>
        <div style="margin-top: 40px">
          <h1>Password Reset!</h1>
          <p>This <%-otp%> is your OTP to reset your password. Do not share this OTP with anyone.</p>
        </div>
      </div>
    </div>
    <div class="footer">
        <table class="footerLinks">
            <tr>
              <td>
                <a href="<%-termsLink%>" style="text-decoration: none; color: unset"
                  >Terms and <br />
                  Conditions</a
                >
              </td>
              <td style="padding-left: 50px; vertical-align: top">
                <a href="<%-privacyLink%>" style="text-decoration: none; color: unset">Privacy</a>
              </td>
            </tr>
          </table>
      <table style="width: 100%; margin-top: 24px">
        <tr>
          <td
            style="
              color: #bebebe;
              font-family: Inter, Arial, 'Google Sans';
              font-size: 12px;
              font-weight: 400;
              line-height: 14.52px;
              vertical-align: top;
            "
          >
            This is an email from Smoketrees Digital <br />
            India
          </td>
          <td style="padding-left: 24px">
            <a href=""
              ><img
                src="https://next-step-server-uploads.s3.ap-south-1.amazonaws.com/email-uploads/facebook.png"
                alt="social links"
                style="width: 45px;"
            /></a>
          </td>
          <td style="padding-left: 24px">
            <a href=""
              ><img
                src="https://next-step-server-uploads.s3.ap-south-1.amazonaws.com/email-uploads/twitter.png"
                alt="social links"
                style="width: 45px;"
            /></a>
          </td>
          <td style="padding-left: 24px">
            <a href=""
              ><img
                src="https://next-step-server-uploads.s3.ap-south-1.amazonaws.com/email-uploads/instagram.png"
                alt="social links"
                style="width: 45px;"
            /></a>
          </td>
        </tr>
      </table>
    </div>
  </body>
</html>
